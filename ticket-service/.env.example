# ── Ticket Service ─────────────────────────────────────────────
# Bu dosyayı kopyalayın: cp .env.example .env

PORT=3002
NODE_ENV=development

# MongoDB bağlantısı (docker-compose'daki ticket-mongo servisi)
MONGO_URI="mongodb://ticket_user:ticket_secret@ticket-mongo:27017/ticket_db?authSource=admin"

# RabbitMQ bağlantısı (docker-compose'daki rabbitmq servisi)
RABBITMQ_URI="amqp://asistcell:asistcell_secret@rabbitmq:5672"

# JWT Access Token secret — Kong'daki JWT_SECRET ile AYNI olmalı (doğrulama için)
JWT_ACCESS_SECRET=change_me_use_a_strong_random_secret_min_32_chars

# Yetkisiz erişim denemelerini identity-service'in merkezi audit log'una yazmak
# için (docker-compose'daki identity-service servisi)
IDENTITY_SERVICE_URL=http://identity-service:3001

# identity-service ile AYNI olmalı — /auth/internal/audit endpoint'ini korur
INTERNAL_API_KEY=change_me_internal_service_key

# COZULDU durumundaki bir talep müşteri onayı almazsa kaç saat sonra Sistem
# tarafından otomatik KAPANDI'ya çekilir (opsiyonel, varsayılan: 48)
TICKET_AUTO_CLOSE_HOURS=48
