# ── AI Service ─────────────────────────────────────────────────
# Bu dosyayı kopyalayın: cp .env.example .env

PORT=3003

# PostgreSQL bağlantısı (docker-compose'daki ai-postgres servisi)
DATABASE_URL=postgresql://ai_user:ai_secret@ai-postgres:5432/ai_db

# Gemini API Key (Gemini entegrasyonu için zorunlu)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model
GEMINI_MODEL=gemini-2.5-flash

# Circuit Breaker Ayarları
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT=30
