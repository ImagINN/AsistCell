# ── AI Service ─────────────────────────────────────────────────
# Bu dosyayı kopyalayın: cp .env.example .env

PORT=3003

# PostgreSQL bağlantısı (docker-compose'daki ai-postgres servisi)
DATABASE_URL=postgresql://ai_user:ai_secret@ai-postgres:5432/ai_db

# RabbitMQ bağlantısı (docker-compose'daki rabbitmq servisi) — ticket.created/
# ticket.released/ticket.rated/ticket.category_changed eventlerini dinler
RABBITMQ_URI="amqp://asistcell:asistcell_secret@rabbitmq:5672"

# Gemini API Key (Gemini entegrasyonu için zorunlu — boşsa analiz her zaman
# yerel modele/BELIRSIZ fallback'e düşer)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model — gemini-2.5-flash emekliye ayrıldığı için "latest" alias
# kullanılır (model emekliliklerinden etkilenmez)
GEMINI_MODEL=gemini-flash-latest

# Circuit Breaker: art arda kaç Gemini hatasından sonra devre açılır (OPEN)
# ve kaç saniye sonra tekrar denenir (HALF_OPEN)
CB_FAILURE_THRESHOLD=3
CB_RECOVERY_TIMEOUT=30
