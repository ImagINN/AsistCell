# ============================================================
# AsistCell — Environment Variables Example
# Kopyalayın: cp .env.example .env
# .env dosyasını asla Git'e commit etmeyin!
# ============================================================

# ── Kong API Gateway ─────────────────────────────────────────
# JWT_SECRET: Identity Service'in token imzalamak için kullandığı
# secret ile AYNI değer olmalı. Minimum 32 karakter önerilir.
JWT_SECRET=change_me_use_a_strong_random_secret_min_32_chars
# .env dosyasını asla Git'e commit etmeyin!
# ============================================================

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=asistcell
RABBITMQ_DEFAULT_PASS=asistcell_secret

# ── Identity Service — PostgreSQL ────────────────────────────
IDENTITY_POSTGRES_DB=identity_db
IDENTITY_POSTGRES_USER=identity_user
IDENTITY_POSTGRES_PASSWORD=identity_secret

# ── AI Service — PostgreSQL ───────────────────────────────────
AI_POSTGRES_DB=ai_db
AI_POSTGRES_USER=ai_user
AI_POSTGRES_PASSWORD=ai_secret

# ── Ticket Service — MongoDB ──────────────────────────────────
TICKET_MONGO_INITDB_ROOT_USERNAME=ticket_user
TICKET_MONGO_INITDB_ROOT_PASSWORD=ticket_secret
TICKET_MONGO_INITDB_DATABASE=ticket_db

# ── Gamification Service — PostgreSQL ────────────────────────
GAMIFICATION_POSTGRES_DB=gamification_db
GAMIFICATION_POSTGRES_USER=gamification_user
GAMIFICATION_POSTGRES_PASSWORD=gamification_secret

# ── Gamification Service — Redis ─────────────────────────────
REDIS_PASSWORD=redis_secret
