# ── Identity Service ─────────────────────────────────────────────
# Bu dosyayı kopyalayın: cp .env.example .env
# Asla Git'e commit etmeyin!

PORT=3001
NODE_ENV=development

# PostgreSQL bağlantısı (docker-compose'daki identity-postgres servisi)
DATABASE_URL="postgresql://identity_user:identity_secret@identity-postgres:5432/identity_db?schema=public"

# JWT Access Token secret — Kong'daki JWT_SECRET ile AYNI olmalı
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars

# JWT Refresh Token secret — Kong'dan bağımsız, sadece bu servis kullanır
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
