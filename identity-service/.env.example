# ── Identity Service ─────────────────────────────────────────────
# Bu dosyayı kopyalayın: cp .env.example .env
# Asla Git'e commit etmeyin!

PORT=3001
NODE_ENV=development

# PostgreSQL bağlantısı (docker-compose'daki identity-postgres servisi)
DATABASE_URL="postgresql://identity_user:identity_secret@identity-postgres:5432/identity_db?schema=public"

# JWT Access Token secret — Kong'daki JWT_SECRET ile AYNI olmalı
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars

# JWT Refresh Token secret — Kong'dan bağımsız, sadece bu servis kullanır
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# İlk kurulumda otomatik ADMIN hesabı oluşturur (yoksa yaratır, varsa ADMIN'e yükseltir).
# Boş bırakılırsa admin seed adımı atlanır.
ADMIN_EMAIL=admin@asistcell.com
ADMIN_PASSWORD=change_me_admin_password

# Servisler arası internal audit endpoint'i (/auth/internal/audit) için paylaşılan
# anahtar — ticket-service bu anahtarla yetkisiz erişim denemelerini buraya yazar.
# Tüm servislerde AYNI değer olmalı.
INTERNAL_API_KEY=change_me_internal_service_key

# Temsilci hesaplarını AI atama havuzuyla senkron tutmak için (docker-compose'daki
# ai-service servisi)
AI_SERVICE_URL=http://ai-service:3003

# Müşteri kaydı GSM+OTP simülasyonu — sabit doğrulama kodu (gerçek SMS sağlayıcısı
# entegre edilene kadar). Varsayılan: 1234
OTP_CODE=1234
