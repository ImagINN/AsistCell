# ── Admin Panel (React/Vite) ──────────────────────────────────
# Bu dosyayı kopyalayın: cp .env.example .env
# Vite değişkenleri BUILD SIRASINDA gömülür — değiştirdikten sonra yeniden
# build/deploy gerekir (docker-compose'da: `docker compose up -d --build admin-panel`).

# API Gateway (Kong) adresi. Boş bırakılırsa http://localhost:8000/api/v1
# kullanılır (docker-compose ile lokal çalıştırmada varsayılan doğrudur).
VITE_API_URL=http://localhost:8000/api/v1
