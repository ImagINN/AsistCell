# ── Demo Generator ─────────────────────────────────────────────
# Bu dosyayı kopyalayın: cp .env.example .env
# Not: docker-compose ile çalıştırıldığında bu değerler zaten kök
# docker-compose.yml içinde tanımlıdır; bu dosya yalnızca servisi
# compose dışında (standalone) çalıştırmak isteyenler içindir.

# API Gateway (Kong) adresi
API_BASE_URL=http://localhost:8000/api/v1

# Yeni talep üretme sıklığı (ms)
INTERVAL_MS=5000

# Sabit test müşteri havuzu boyutu
CUSTOMER_POOL_SIZE=8

# Bot temsilcilerin talepleri ilerletme sıklığı (ms)
AGENT_TICK_MS=4000

# Bot süpervizörün bekleyen/atanmamış talepleri kontrol sıklığı (ms)
SUPERVISOR_TICK_MS=6000

# Bu süreden uzun süredir ATANDI durumunda kalan (temsilci ilerletmeyen)
# talepleri bot süpervizör yeniden değerlendirir (ms)
STALE_ASSIGNMENT_MS=90000

# Müşteri kaydı OTP simülasyonu — identity-service'teki OTP_CODE ile AYNI olmalı
OTP_CODE=1234

# Bot müşteri/temsilci hesaplarının şifreleri (identity-service şifre politikasına uymalı)
DEMO_PASSWORD=DemoMusteri!2026
AGENT_PASSWORD=DemoTemsilci!2026

# Bot temsilci/süpervizör hesaplarını oluşturmak için admin girişi —
# identity-service/.env'deki ADMIN_EMAIL/ADMIN_PASSWORD ile AYNI olmalı
ADMIN_EMAIL=admin@asistcell.com
ADMIN_PASSWORD=change_me_admin_password
