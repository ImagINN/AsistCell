# ── Gamification Service ──────────────────────────────────────
# Bu dosyayı kopyalayın: cp .env.example .env

PORT=3004
NODE_ENV=development

# PostgreSQL bağlantısı (docker-compose'daki gamification-postgres servisi)
DATABASE_URL="postgresql://gamification_user:gamification_secret@gamification-postgres:5432/gamification_db?schema=public"

# Redis bağlantısı (docker-compose'daki gamification-redis servisi)
REDIS_HOST=gamification-redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# RabbitMQ bağlantısı (docker-compose'daki rabbitmq servisi) — ticket.resolved
# ve ticket.rated eventlerini dinleyip puan/rozet işler
RABBITMQ_URI="amqp://asistcell:asistcell_secret@rabbitmq:5672"

# JWT Access Token secret — Kong'daki JWT_SECRET ile AYNI olmalı (doğrulama için)
JWT_ACCESS_SECRET=change_me_use_a_strong_random_secret_min_32_chars
